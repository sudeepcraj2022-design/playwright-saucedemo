{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": [
        "pages/*"
      ],
      "@fixtures/*": [
        "fixtures/*"
      ],
      "@utils/*": [
        "utils/*"
      ],
      "@config/*": [
        "config/*"
      ]
    },
    "types": [
      "node",
      "@playwright/test"
    ],
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "tests",
    "pages",
    "fixtures",
    "utils",
    "config",
    "constants",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}